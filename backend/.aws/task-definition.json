{
  "containerDefinitions": [
    {
      "name": "anh-backend",
      "image": "899032468368.dkr.ecr.ap-southeast-2.amazonaws.com/anh-backend:latest",
      "cpu": 0,
      "portMappings": [
        {
          "name": "anh-backend-3001-tcp",
          "containerPort": 3001,
          "hostPort": 3001,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "PORT",
          "value": "3001"
        },
        {
          "name": "ALLOWED_ORIGIN",
          "value": "http://localhost:3000"
        }
      ],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/anh-backend-task",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "systemControls": []
    }
  ],
  "family": "anh-backend-task",
  "executionRoleArn": "arn:aws:iam::899032468368:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "tags": []
}
